rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /games/{gameId} {
      // Small private pool rules. Anyone signed in anonymously can read and update
      // game settings, so share only with trusted friends.
      allow read: if true;
      allow write: if request.auth != null;

      match /predictions/{playerId} {
        allow read: if true;
        allow create, update: if request.auth != null
          && request.resource.data.keys().hasOnly([
            'playerId', 'name', 'picks', 'scorePredictions', 'createdAt', 'updatedAt'
          ])
          && request.resource.data.name is string
          && request.resource.data.name.size() > 0
          && request.resource.data.name.size() <= 40
          && request.resource.data.picks is map
          && request.resource.data.scorePredictions is map;
        allow delete: if false;
      }
    }
  }
}
